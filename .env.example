# Configuration Supabase pour Quotex (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-project-id.supabase.co/functions/v1

# Après avoir configuré EXPO_PUBLIC_SUPABASE_URL, générez les types de la base de données :
# npm run types:generate
