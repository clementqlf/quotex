{
  "expo": {
    "name": "Quotex",
    "slug": "quotex",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "quotex",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quotex.app",
      "icon": "./assets/icon.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "Quotex a besoin d'accéder à votre appareil photo pour numériser (OCR) du texte de citations à partir de livres physiques."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.quotex.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/quotex_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Quotex requiert l'accès à vos photos uniquement pour vous permettre de sélectionner des images de citations ou des couvertures de livres à importer.",
          "cameraPermission": "Quotex a besoin d'accéder à votre appareil photo pour numériser (OCR) du texte de citations à partir de livres physiques."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Quotex a besoin d'accéder à votre appareil photo pour numériser (OCR) du texte de citations à partir de livres physiques.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "635592710276-ejpo7l1bi3jkv6oh1hpd24clnudds1co.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.635592710276-ejpo7l1bi3jkv6oh1hpd24clnudds1co"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "./plugins/withSecureWebView"
    ],
    "updates": {
      "url": "https://u.expo.dev/@quotex/quotex",
      "enabled": true,
      "fallbackToCacheTimeout": 300000
    },
    "runtimeVersion": "1.0.0",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "eaa0560e-b9b6-4344-a4ab-3d9283e277f9"
      }
    },
    "owner": "clementqlf"
  }
}
