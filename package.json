{
  "name": "quotex",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "types:generate": "npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/shared/types/database.ts",
    "eas:build:dev": "eas build --profile dev --platform all",
    "eas:build:staging": "eas build --profile staging --platform all",
    "eas:build:prod": "eas build --profile prod --platform all",
    "eas:update:dev": "eas update --branch dev --message",
    "eas:update:staging": "eas update --branch staging --message",
    "eas:update:prod": "eas update --branch production --message",
    "channels:create": "chmod +x ./scripts/create-channels.sh && ./scripts/create-channels.sh",
    "eas:submit:prod": "eas submit --profile prod",
    "postinstall": "node scripts/patch-gradle-foojay.js"
  },
  "dependencies": {
