require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, '15.5'

prepare_react_native_project!

# iOS New Architecture flag
ENV['RCT_NEW_ARCH_ENABLED'] = '1'  # '1' = New Architecture, '0' = Legacy

target 'Quotex' do
  config = use_native_modules!


  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => true,
    :new_arch_enabled => true
  )

  # Pods additionnels éventuels (exemple)

end

post_install do |installer|
  react_native_post_install(installer)

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|

      # RN → C++20
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

      # 🔥 FIX fmt
      if target.name == 'fmt'
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'

        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] =
          (config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']) + [
            'FMT_ENFORCE_COMPILE_STRING=0',
            'FMT_USE_CONSTEXPR=0',
            'FMT_USE_CONSTEXPR_STATIC_ASSERT=0',
            'FMT_USE_NONTYPE_TEMPLATE_ARGS=0'
          ]

        config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-DFMT_HEADER_ONLY=1'
      end

    end
  end
end