generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Book Model Updates
model Book {
  id            Int     @id @default(autoincrement())
  title         String
  description   String?
  year          Int?
  pages         Int?
  cover         String?
  genre         String?
  rating        Float?
  buyLinks      String? // JSON string: Array<{ store: string; url: string; price: string }>
  googleId      String? @unique
  openLibraryId String? @unique
  inventaireUri String? @unique // URI Inventaire/Wikidata: ex. "wd:Q34670" ou "inv:abc123"
  isbn          String?

  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  isEnriching      Boolean   @default(false)
  lastEnrichedAt   DateTime?
  lastDiscoveredAt DateTime?

  // Relations
  users    UserBook[]
  quotes   Quote[]
  reviews  Review[]
  editions Edition[]

  // Self-relation for similar books
  similarBooks Book[] @relation("SimilarBooks")
  similarTo    Book[] @relation("SimilarBooks")

  @@unique([title, authorId])
}

// Author Model Updates
model Author {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  description   String?
  image         String?
  birthDate     String?
  nationality   String?
  inventaireUri String? @unique // URI Wikidata: ex. "wd:Q34670"
  books         Book[]
  quotes        Quote[]

  isEnriching      Boolean   @default(false)
  lastEnrichedAt   DateTime?
  lastDiscoveredAt DateTime?

  users UserAuthor[]

  // Self-relation for similar authors
  similarAuthors Author[] @relation("SimilarAuthors")
  similarTo      Author[] @relation("SimilarAuthors")
}

model Quote {
  id   Int    @id @default(autoincrement())
  text String

  // Relations
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  bookId Int?
  book   Book? @relation(fields: [bookId], references: [id], onDelete: SetNull)

  likes      Like[]
  likesCount Int         @default(0)
  savedBy    UserQuote[]
  date       DateTime    @default(now())
  theme      String?

  // New rich data
  aiInterpretation String?
  definitions      String? // JSON string: Array<{ term: string; genre: string; definition: string; example: string }>
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  email     String  @unique
  password  String
  name      String?
  image     String?
  bio       String?
  website   String?
  followers Int     @default(0)
  following Int     @default(0)

  library     UserBook[]
  authors     UserAuthor[]
  savedQuotes UserQuote[]

  quotes  Quote[]
  reviews Review[]
  likes   Like[]
}

model UserBook {
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  status  String? // reading, finished, to-read
  addedAt DateTime @default(now())

  @@id([userId, bookId])
}

model UserAuthor {
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@id([userId, authorId])
}

model UserQuote {
  userId  Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteId Int
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@id([userId, quoteId])
}

model Like {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  quoteId Int
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// Cache for Inventaire search results
model SearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  type      String // "works" | "humans"
  results   String // JSON string
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([query, type])
}

// Cached editions from Inventaire.io for a given work
model Edition {
  id            Int      @id @default(autoincrement())
  inventaireUri String   @unique // ex. "isbn:9782070364770" or "inv:abc123"
  isbn          String?
  title         String?
  publishDate   String?
  publisherUri  String? // Wikidata URI of publisher, ex. "wd:Q273819"
  publisherName String? // Resolved human-readable name
  languageUri   String? // ex. "wd:Q150" for French
  cover         String? // Full URL to cover image
  pages         Int?
  bookId        Int
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
