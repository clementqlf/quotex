generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Book Model Updates
model Book {
  id            Int     @id @default(autoincrement())
  title         String  @unique
  description   String?
  year          Int?
  pages         Int?
  cover         String?
  genre         String?
  rating        Float?
  buyLinks      String? // JSON string: Array<{ store: string; url: string; price: string }>
  googleId      String? @unique
  openLibraryId String? @unique
  isbn          String?

  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  isSaved Boolean @default(false)

  // Relations
  quotes  Quote[]
  reviews Review[]

  // Self-relation for similar books
  similarBooks Book[] @relation("SimilarBooks")
  similarTo    Book[] @relation("SimilarBooks")
}

// Author Model Updates
model Author {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  image       String?
  birthDate   String?
  nationality String?
  books       Book[]
  quotes      Quote[]

  isSaved Boolean @default(false)

  // Self-relation for similar authors
  similarAuthors Author[] @relation("SimilarAuthors")
  similarTo      Author[] @relation("SimilarAuthors")
}

model Quote {
  id   Int    @id @default(autoincrement())
  text String

  // Relations
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorId Int
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  bookId Int?
  book   Book? @relation(fields: [bookId], references: [id], onDelete: SetNull)

  likes      Like[]
  likesCount Int      @default(0)
  isSaved    Boolean  @default(false)
  date       DateTime @default(now())
  theme      String?

  // New rich data
  aiInterpretation String?
  definitions      String? // JSON string: Array<{ term: string; genre: string; definition: string; example: string }>
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String?
  image     String?
  bio       String?
  website   String?
  followers Int      @default(0)
  following Int      @default(0)
  quotes    Quote[]
  reviews   Review[]
  likes     Like[]
}

model Like {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  quoteId Int
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([userId, quoteId])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}
